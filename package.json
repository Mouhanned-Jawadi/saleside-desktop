{
  "name": "saleside-desktop",
  "version": "1.0.0",
  "description": "SaleSide — AI-powered sales coaching desktop application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:portable": "electron-builder --config.win.target=portable",
    "dist:signed": "electron-builder"
  },
  "author": {
    "name": "SaleSide"
  },
  "license": "ISC",
  "dependencies": {
    "@recallai/desktop-sdk": "latest",
    "express": "^4.18.2",
    "http-proxy-middleware": "^2.0.6"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.saleside.desktop",
    "productName": "SaleSide",
    "copyright": "Copyright © 2025 SaleSide. All rights reserved.",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "icon.ico",
      "publisherName": "SaleSide",
      "signingHashAlgorithms": ["sha256"],
      "asarUnpack": [
        "dist/**/*",
        "node_modules/@recallai/desktop-sdk/**/*"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "runAfterFinish": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SaleSide",
      "differentialPackage": false
    },
    "portable": {
      "artifactName": "SaleSide-Portable-${version}.exe"
    }
  }
}
